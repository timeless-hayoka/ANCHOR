# Copy to your Damn Vulnerable DeFi checkout as `.env`:
#   cp benchmarks/damn-vulnerable-defi/env.example /home/crexs/damn-vulnerable-defi/.env
#
# Or export in your shell before running benchmarks:
#   export MAINNET_FORKING_URL=https://your-archive-provider/...

# Archive-capable Ethereum mainnet HTTPS endpoint (required for puppet-v3 and curvy-puppet).
# PublicNode example (requires free personal token from https://www.allnodes.com/publicnode):
# MAINNET_FORKING_URL=https://ethereum.publicnode.com/YOUR_TOKEN_HERE

MAINNET_FORKING_URL=
